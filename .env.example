# Server-side only. Never prefix this value with NEXT_PUBLIC_.
OPENAI_API_KEY=

# Required in production. Protects the entire app and its API routes with HTTP Basic Auth.
HFC_AUTH_USERNAME=
HFC_AUTH_PASSWORD=

# Model names are server-side only. The Realtime client receives a short-lived credential,
# never this API key or model configuration. The Realtime model performs server VAD;
# the transcription model produces completed input-audio transcript turns.
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_EDIT_MODEL=gpt-5-mini

# Set to mock for deterministic proposal review without an API key.
HFC_EDIT_ADAPTER=

# Optional explicit transport choice. Leave empty to infer it from the configured provider key.
HFC_VOICE_MODE=

# Optional one-utterance fallback for providers without Realtime WebRTC.
# Audio is recorded in the browser, transcribed server-side, and never persisted.
OPENROUTER_API_KEY=
OPENROUTER_TRANSCRIPTION_MODEL=openai/gpt-4o-transcribe
